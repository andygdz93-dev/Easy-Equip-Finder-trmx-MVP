# ── Required ──────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-random-32-char-string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set to "true" to serve seeded listings without a database
DEMO_MODE=false

# ── PostgreSQL (optional — falls back to demo data if not set) ────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=easyfinder
DB_USER=postgres
DB_PASSWORD=

# ── Stripe (optional — payments disabled if not set) ─────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
CLIENT_URL=http://localhost:5173

# ── Anthropic AI Broker (optional — broker chat disabled if not set) ──────────
# Get your key at https://console.anthropic.com
# Without this, POST /api/broker/chat returns 503 gracefully.
ANTHROPIC_API_KEY=sk-ant-...
