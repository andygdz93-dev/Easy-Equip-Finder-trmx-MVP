# Dependencies — always regenerated by pnpm install
node_modules/

# Compiled TypeScript output — regenerated by pnpm build
dist/
build/

# Vite internal cache
.vite/

# Environment files — contain secrets, NEVER commit these
.env
.env.local
.env.*.local

# Runtime logs — deployment artifacts, not source code
*.log
api_run.log
web_run.log

# PID files — ephemeral runtime state
*.pid

# OS generated files
.DS_Store
Thumbs.db

# Editor config
.vscode/
.idea/
